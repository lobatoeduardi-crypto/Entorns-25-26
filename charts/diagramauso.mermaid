flowchart LR
 subgraph Sistema["Sistema"]
        UC1["Registrarse"]
        UC2["Iniciar sesión"]
        UC3["Ver perfil"]
        UC4["Editar perfil"]
        UC5["Realizar compra"]
        UC6["Gestionar usuarios"]
        UC7["Gestionar productos"]
        UC8["Ver reportes"]
