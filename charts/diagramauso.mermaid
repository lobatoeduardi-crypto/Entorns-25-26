    Usuario(("Usuario")) --> UC1 & UC2 & UC3 & UC4 & UC5
    Admin(("Administrador")) --> UC2 & UC6 & UC7 & UC8
    UC9["Filtrar Reportes" -- Uses] -.-> UC8